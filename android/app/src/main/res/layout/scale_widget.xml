<?xml version="1.0" encoding="utf-8"?>
<!-- 2×2 全量小组件：暗色液态玻璃 — 缩小字体防溢出 -->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="10dp"
    android:background="@drawable/widget_bg_dark_glass_flat">

    <!-- 标题 -->
    <TextView
        android:id="@+id/widget_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:text="体脂秤"
        android:textColor="#8899BB"
        android:textSize="11sp"
        android:maxLines="1" />

    <!-- 体重 (大号) -->
    <TextView
        android:id="@+id/widget_weight"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/widget_title"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="2dp"
        android:text="--"
        android:textColor="#F0F0FF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end" />

    <!-- kg -->
    <TextView
        android:id="@+id/widget_unit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/widget_weight"
        android:layout_centerHorizontal="true"
        android:text="kg"
        android:textColor="#667799"
        android:textSize="12sp"
        android:maxLines="1" />

    <!-- 底部时间 -->
    <TextView
        android:id="@+id/widget_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:text=""
        android:textColor="#445577"
        android:textSize="9sp"
        android:maxLines="1" />

    <!-- 三列指标 (放在体重和时间之间) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/widget_unit"
        android:layout_above="@id/widget_time"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- 体脂 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/widget_fat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#FF9F43"
                android:textSize="15sp"
                android:textStyle="bold"
                android:maxLines="1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="体脂率"
                android:textColor="#556688"
                android:textSize="10sp"
                android:maxLines="1" />
        </LinearLayout>

        <!-- BMI -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/widget_bmi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#54A0FF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:maxLines="1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BMI"
                android:textColor="#556688"
                android:textSize="10sp"
                android:maxLines="1" />
        </LinearLayout>

        <!-- 肌肉率 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/widget_muscle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#2ED573"
                android:textSize="15sp"
                android:textStyle="bold"
                android:maxLines="1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="肌肉率"
                android:textColor="#556688"
                android:textSize="10sp"
                android:maxLines="1" />
        </LinearLayout>

    </LinearLayout>

</RelativeLayout>
