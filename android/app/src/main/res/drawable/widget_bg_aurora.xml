<?xml version="1.0" encoding="utf-8"?>
<!-- 极光渐变 — 青紫过渡 -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="45"
                android:startColor="#E8F5E9"
                android:centerColor="#E3F2FD"
                android:endColor="#F3E5F5" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    <item android:top="2dp" android:bottom="2dp" android:left="6dp" android:right="6dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="45"
                android:startColor="#60FFFFFF"
                android:centerColor="#20FFFFFF"
                android:endColor="#40FFFFFF" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <stroke android:width="1dp" android:color="#40FFFFFF" />
            <corners android:radius="20dp" />
        </shape>
    </item>
</layer-list>
