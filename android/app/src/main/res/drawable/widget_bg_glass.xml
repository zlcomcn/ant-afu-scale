<?xml version="1.0" encoding="utf-8"?>
<!-- 液态玻璃风格 — 白底蓝调 -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 底层：微弱渐变 -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#F0F4FF"
                android:endColor="#E8EEFB" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    <!-- 高光条 -->
    <item
        android:top="2dp"
        android:bottom="2dp"
        android:left="6dp"
        android:right="6dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#B0FFFFFF"
                android:centerColor="#40FFFFFF"
                android:endColor="#00FFFFFF" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <!-- 边框 -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <stroke
                android:width="1dp"
                android:color="#30FFFFFF" />
            <corners android:radius="20dp" />
        </shape>
    </item>
</layer-list>
