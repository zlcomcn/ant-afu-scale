<?xml version="1.0" encoding="utf-8"?>
<!-- 默认液态玻璃 — 白底微蓝 -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#F8F9FF"
                android:endColor="#EEF1FA" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    <item android:top="2dp" android:bottom="2dp" android:left="6dp" android:right="6dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#90FFFFFF"
                android:centerColor="#30FFFFFF"
                android:endColor="#00FFFFFF" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <stroke android:width="0.5dp" android:color="#20FFFFFF" />
            <corners android:radius="20dp" />
        </shape>
    </item>
</layer-list>
